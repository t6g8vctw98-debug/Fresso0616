# ─── Fresso backend environment variables ──────────────────────────────────
# Copy this file to `.env` and fill in real values before running the server.
# In production, never commit `.env` to git.

# ─── Flask / security ──────────────────────────────────────────────────────
# Used to sign session cookies & related crypto. MUST be set in production.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# In dev, if unset the backend auto-generates one and persists it to
# instance/.secret_key so sessions survive restarts.
SECRET_KEY=

# Set to "production" to disable dev conveniences (auto-generated SECRET_KEY,
# verbose error responses, debug mode). Leave empty or "development" locally.
FLASK_ENV=development

# Comma-separated list of allowed CORS origins for the frontend.
# IMPORTANT: the backend reads this from the CORS_ORIGINS variable (not
# FRONTEND_ORIGINS). The Fresso web frontend dev server runs on port 5000.
# Set to "*" to allow any origin (not recommended outside local dev).
# Examples:
#   CORS_ORIGINS=http://localhost:5000,http://localhost:5173
#   CORS_ORIGINS=https://fresso.app
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# ─── Database ──────────────────────────────────────────────────────────────
# Leave unset for local dev: the backend automatically creates an SQLite DB
# at an absolute path inside its instance/ folder. Do NOT set a relative
# 'sqlite:///instance/...' URI here — Flask resolves it relative to the
# instance folder, producing instance/instance/... which fails to open.
# Only set this for a custom DB, e.g. Postgres:
#   DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
# DATABASE_URL=

# ─── USDA FoodData Central ────────────────────────────────────────────────
# Free key (3600 req/hr per IP) — register here:
#   https://fdc.nal.usda.gov/api-key-signup.html
# If unset, the backend will use DEMO_KEY (30 req/hr, easily hit).
USDA_API_KEY=

# ─── OpenAI (optional but recommended) ─────────────────────────────────────
# Powers:
#   • AI-based recipe extraction fallback when scrapers fail
#   • AI nutrition fallback when USDA returns no match
# If unset, those features gracefully no-op and return empty / zero-filled
# results.
OPENAI_API_KEY=
